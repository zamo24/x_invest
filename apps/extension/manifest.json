{
  "manifest_version": 3,
  "name": "Investor Research Copilot",
  "description": "Save X post URLs through the official integration and chat over your research library.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "sidePanel"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Investor Research Copilot"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
