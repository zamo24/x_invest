# -----------------------------
# API core
# -----------------------------
APP_VERSION=0.1.0
APP_NAME=Investor Research Copilot API
APP_ENV=development
LOG_LEVEL=INFO
TOKEN_PEPPER=replace-with-long-random-secret
PAT_DEFAULT_TTL_DAYS=90
PAT_MAX_TTL_DAYS=365
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_REQUESTS=30
RATE_LIMIT_INGEST_REQUESTS=60
RATE_LIMIT_TOKEN_REQUESTS=30
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
EMBEDDING_MAX_TOKENS=6000
EMBEDDING_MAX_CHARS=24000
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
RETRIEVAL_OVERSAMPLE_MULTIPLIER=6
RETRIEVAL_MIN_CANDIDATES=30
RETRIEVAL_LEXICAL_WEIGHT=0.18
RETRIEVAL_RECENCY_WEIGHT=0.04
HOSTED_CHAT_PROVIDER=openai
HOSTED_CHAT_MODELS=gpt-4o-mini,gpt-4.1-mini,gpt-5-mini,gpt-5.2
BYOK_ENCRYPTION_KEY=replace-with-long-random-secret-or-fernet-key
EMBEDDING_DIM=256

# -----------------------------
# Official X API integration
# -----------------------------
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/v1/integrations/x/callback
X_TOKEN_ENCRYPTION_KEY=replace-with-long-random-secret-or-fernet-key
X_API_BASE_URL=https://api.x.com
X_CONTENT_REVALIDATE_HOURS=24
X_MONTHLY_POST_READ_BUDGET=10000
X_BOOKMARK_SYNC_POST_LIMIT=1000
X_INTEGRATION_SETTINGS_URL=http://localhost:3000/app/settings/x

# -----------------------------
# Clerk (web auth + API JWT verification)
# -----------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_JWT_LEEWAY_SECONDS=30
CLERK_JWT_TEMPLATE=

# -----------------------------
# CORS
# -----------------------------
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Development only. Clear this in production and set exact CORS_EXTENSION_IDS.
CORS_ALLOW_ORIGIN_REGEX=^chrome-extension://[a-z]{32}$
CORS_EXTENSION_IDS=
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type

# -----------------------------
# Web -> API
# -----------------------------
API_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BETA_APPLICATION_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_PRODUCT_NAME=Investor Research Copilot
